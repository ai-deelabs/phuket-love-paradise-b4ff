---
import { Image } from 'astro:assets';
import avatarNira from '../assets/avatar_nira.jpg';
import { t, type L, type Lang } from '../i18n/config';
import {
  EMAIL,
  FACEBOOK_URL,
  HOURS,
  LINE_ADD_URL,
  LINE_ID,
  PHONE,
  PHONE_DISPLAY,
  SITE_NAME,
  WHATSAPP_NUMBER,
} from '../lib/site';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const label: L = { th: 'ติดต่อเรา', en: 'Get in Touch', ru: 'Связаться с нами' };
const title: L = {
  th: 'พร้อมช่วยวางแผนทริปในฝันของคุณ',
  en: 'Ready to Plan Your Dream Trip',
  ru: 'Готовы спланировать поездку вашей мечты',
};
const desc: L = {
  th: 'เลือกช่องทางที่สะดวกสำหรับคุณ ทีมงานของเราพร้อมตอบทุกคำถามและช่วยจองทัวร์ให้คุณ',
  en: 'Reach us through whichever channel suits you best — our team is ready to answer your questions and book your tour.',
  ru: 'Свяжитесь с нами удобным способом — наша команда ответит на вопросы и забронирует тур.',
};
const consultantRole: L = {
  th: 'ที่ปรึกษาการเดินทางส่วนตัวของคุณ',
  en: 'Your personal travel consultant',
  ru: 'Ваш персональный консультант',
};

const phoneTitle: L = { th: 'โทรศัพท์', en: 'Phone', ru: 'Телефон' };
const emailTitle: L = { th: 'อีเมล', en: 'Email', ru: 'Эл. почта' };
const locationTitle: L = {
  th: 'ที่ตั้ง · เวลาทำการ',
  en: 'Location · Hours',
  ru: 'Адрес · Часы',
};
const locationLine: L = {
  th: `ภูเก็ต ประเทศไทย · ทุกวัน ${HOURS} น.`,
  en: `Phuket, Thailand · Daily ${HOURS}`,
  ru: `Пхукет, Таиланд · Ежедневно ${HOURS}`,
};
---

<section class="sec contact" id="contact">
  <div class="container contact__inner">
    <div class="contact__lead reveal">
      <div class="sec-label">
        <Icon name="message-circle" size={14} />
        <span>{t(label, lang)}</span>
      </div>
      <h2 class="sec-title lt">{t(title, lang)}</h2>
      <p class="sec-desc lt">{t(desc, lang)}</p>
      <div class="contact__person">
        <Image src={avatarNira} alt={t(consultantRole, lang)} width={100} height={100} />
        <span>
          <strong>คุณนิรา จันทรวงศ์ · Nira Chandrawong</strong>
          <span>{t(consultantRole, lang)}</span>
        </span>
      </div>
    </div>

    <div class="contact__grid">
      <a class="ccard reveal" href={`tel:${PHONE}`}>
        <div class="ccard__ic phone"><Icon name="phone" size={22} /></div>
        <div class="ccard__tx">
          <h4>{t(phoneTitle, lang)}</h4>
          <p>{PHONE_DISPLAY}</p>
        </div>
      </a>
      <a class="ccard reveal rd1" href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener">
        <div class="ccard__ic wa"><Icon name="message-circle" size={22} /></div>
        <div class="ccard__tx">
          <h4>WhatsApp</h4>
          <p>{PHONE_DISPLAY}</p>
        </div>
      </a>
      <a class="ccard reveal rd2" href={LINE_ADD_URL} target="_blank" rel="noopener">
        <div class="ccard__ic line"><Icon name="message-square" size={22} /></div>
        <div class="ccard__tx">
          <h4>LINE</h4>
          <p>{LINE_ID}</p>
        </div>
      </a>
      <a class="ccard reveal" href={FACEBOOK_URL} target="_blank" rel="noopener">
        <div class="ccard__ic fb"><Icon name="facebook" size={22} /></div>
        <div class="ccard__tx">
          <h4>Facebook</h4>
          <p>{SITE_NAME}</p>
        </div>
      </a>
      <a class="ccard reveal rd1" href={`mailto:${EMAIL}`}>
        <div class="ccard__ic mail"><Icon name="mail" size={22} /></div>
        <div class="ccard__tx">
          <h4>{t(emailTitle, lang)}</h4>
          <p>{EMAIL}</p>
        </div>
      </a>
      <div class="ccard reveal rd2">
        <div class="ccard__ic map"><Icon name="map-pin" size={22} /></div>
        <div class="ccard__tx">
          <h4>{t(locationTitle, lang)}</h4>
          <p>{t(locationLine, lang)}</p>
        </div>
      </div>
    </div>
  </div>
</section>
