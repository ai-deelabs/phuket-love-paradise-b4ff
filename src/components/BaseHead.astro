---
import { DEFAULT_LANG, LOCALES, OG_LOCALES, type Lang } from '../i18n/config';
import type { Alternates } from '../lib/routes';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  alternates: Alternates;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
}

const {
  lang,
  title,
  description,
  alternates,
  ogImage,
  ogType = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const site = Astro.site!;
const abs = (path: string) => new URL(path, site).href;
const canonical = abs(alternates[lang]);
const ogImageAbs = ogImage ? abs(ogImage) : undefined;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{
  !noindex &&
    LOCALES.map((l) => <link rel="alternate" hreflang={l === 'th' ? 'th-TH' : l} href={abs(alternates[l])} />)
}
{!noindex && <link rel="alternate" hreflang="x-default" href={abs(alternates[DEFAULT_LANG])} />}

<meta property="og:site_name" content="Phuket Love Paradise" />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={OG_LOCALES[lang]} />
{ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
<meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
  rel="stylesheet"
/>
{jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
