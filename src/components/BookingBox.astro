---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/config';
import { useT } from '../i18n/ui';
import { formatBaht } from '../lib/images';
import { cartUrl } from '../lib/routes';
import Icon from './Icon.astro';

interface Props {
  tour: CollectionEntry<'tours'>;
  lang: Lang;
}
const { tour, lang } = Astro.props;
const t = useT(lang);
const d = tour.data;

const first = d.variants[0]!;

// Client payload: everything the booking script needs, keyed by variant id.
const payload = {
  tour: tour.id,
  cartUrl: cartUrl(lang),
  addedLabel: t('common.addedToCart'),
  variants: Object.fromEntries(
    d.variants.map((v) => [
      v.id,
      {
        adult: v.adult,
        child: v.child,
        adultLabel: v.adultLabel?.[lang] ?? t('booking.adults'),
        childLabel: v.childLabel?.[lang] ?? t('booking.children'),
      },
    ]),
  ),
};

const optionLabel = (v: (typeof d.variants)[number]) =>
  `${v.group ? `${v.group[lang]} · ` : ''}${v.label[lang]} — ${formatBaht(v.adult)}`;
---

<div class="bbox" id="bookingBox">
  <h2>{t('booking.title')}</h2>
  <div class="fg">
    <label for="bkVariant">{t('booking.selectProgram')}</label>
    <select id="bkVariant">
      {d.variants.map((v) => <option value={v.id}>{optionLabel(v)}</option>)}
    </select>
  </div>
  <div class="fg">
    <label for="bkDate">{t('common.date')}</label>
    <input type="date" id="bkDate" />
  </div>
  <div class="bbox__row">
    <div class="stepper" id="bkAdults">
      <button type="button" data-step="-1" aria-label="−">−</button>
      <span class="val">2</span>
      <button type="button" data-step="1" aria-label="+">+</button>
      <span class="who">{first.adultLabel?.[lang] ?? t('booking.adults')}</span>
    </div>
  </div>
  <div class="bbox__row" id="bkChildRow">
    <div class="stepper" id="bkChildren">
      <button type="button" data-step="-1" aria-label="−">−</button>
      <span class="val">0</span>
      <button type="button" data-step="1" aria-label="+">+</button>
      <span class="who">{first.childLabel?.[lang] ?? t('booking.children')}</span>
    </div>
  </div>
  <div class="bbox__total">
    <span class="lbl">{t('common.total')}</span>
    <span class="amt" id="bkTotal">{formatBaht(first.adult * 2)}</span>
  </div>
  <div class="bbox__btns">
    <button type="button" class="btn-gold" id="bkBook">
      <Icon name="calendar-check" size={16} />
      {t('common.bookNow')}
    </button>
    <button type="button" class="btn-navy" id="bkAdd">
      <Icon name="shopping-cart" size={16} />
      {t('common.addToCart')}
    </button>
  </div>
  <p class="bbox__note">{t('booking.note')}</p>
</div>

<script type="application/json" id="bkData" set:html={JSON.stringify(payload)} />

<script>
  import { addItem } from '../scripts/cart';

  const data = JSON.parse(document.getElementById('bkData')!.textContent!) as {
    tour: string;
    cartUrl: string;
    addedLabel: string;
    variants: Record<
      string,
      { adult: number; child: number | null; adultLabel: string; childLabel: string }
    >;
  };

  const select = document.getElementById('bkVariant') as HTMLSelectElement;
  const dateInput = document.getElementById('bkDate') as HTMLInputElement;
  const totalEl = document.getElementById('bkTotal')!;
  const childRow = document.getElementById('bkChildRow')!;
  const addBtn = document.getElementById('bkAdd') as HTMLButtonElement;
  const bookBtn = document.getElementById('bkBook') as HTMLButtonElement;

  const today = new Date();
  today.setDate(today.getDate() + 1);
  dateInput.min = today.toISOString().slice(0, 10);

  const counts = { adults: 2, children: 0 };
  const fmt = (n: number) => `฿${n.toLocaleString('en-US')}`;
  const variant = () => data.variants[select.value]!;

  function render() {
    const v = variant();
    childRow.style.display = v.child === null ? 'none' : '';
    if (v.child === null) counts.children = 0;
    document.querySelector('#bkAdults .who')!.textContent = v.adultLabel;
    document.querySelector('#bkChildren .who')!.textContent = v.childLabel;
    document.querySelector('#bkAdults .val')!.textContent = String(counts.adults);
    document.querySelector('#bkChildren .val')!.textContent = String(counts.children);
    totalEl.textContent = fmt(v.adult * counts.adults + (v.child ?? 0) * counts.children);
  }

  function bindStepper(id: 'bkAdults' | 'bkChildren', key: 'adults' | 'children', min: number) {
    document.querySelectorAll(`#${id} button`).forEach((btn) => {
      btn.addEventListener('click', () => {
        const step = Number((btn as HTMLElement).dataset.step);
        counts[key] = Math.min(40, Math.max(min, counts[key] + step));
        render();
      });
    });
  }

  bindStepper('bkAdults', 'adults', 1);
  bindStepper('bkChildren', 'children', 0);
  select.addEventListener('change', render);
  render();

  function add(): void {
    addItem({
      tour: data.tour,
      variant: select.value,
      date: dateInput.value || '',
      adults: counts.adults,
      children: counts.children,
    });
  }

  addBtn.addEventListener('click', () => {
    add();
    const original = addBtn.innerHTML;
    addBtn.textContent = data.addedLabel;
    setTimeout(() => {
      addBtn.innerHTML = original;
    }, 1600);
  });

  bookBtn.addEventListener('click', () => {
    add();
    window.location.href = data.cartUrl;
  });
</script>
