---
import { getImage } from 'astro:assets';
import type { Lang } from '../../i18n/config';
import { assetImage } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const bg = await getImage({ src: assetImage('stats_bg.jpg'), width: 1920, format: 'webp' });

const title = {
  th: 'ความไว้วางใจจากนักเดินทางทั่วโลก',
  en: 'Trusted by Travellers Worldwide',
  ru: 'Нам доверяют путешественники по всему миру',
}[lang];

const stats = [
  {
    cls: 'reveal rd1',
    num: '10+',
    lbl: {
      th: 'ปีแห่งประสบการณ์',
      en: 'Years of Experience',
      ru: 'лет опыта',
    },
  },
  {
    cls: 'reveal rd2',
    num: '5,000+',
    lbl: {
      th: 'นักเดินทางพึงพอใจ',
      en: 'Happy Travellers',
      ru: 'довольных путешественников',
    },
  },
  {
    cls: 'reveal rd3',
    num: '4.9',
    lbl: {
      th: 'คะแนนเฉลี่ยจากลูกค้า',
      en: 'Average Rating',
      ru: 'средняя оценка',
    },
  },
  {
    cls: 'reveal rd4',
    num: '25+',
    lbl: {
      th: 'จุดหมายสุดพิเศษ',
      en: 'Unique Destinations',
      ru: 'уникальных направлений',
    },
  },
];
---

<section class="stats" style={`--stats-bg:url(${bg.src})`}>
  <div class="stats__bg"></div>
  <div class="stats__veil"></div>
  <div class="stats__inner">
    <h2 class="stats__ttl reveal">{title}</h2>
    <div class="stats__grid">
      {
        stats.map((s) => (
          <div class={s.cls}>
            <span class="stat__num">{s.num}</span>
            <span class="stat__lbl">{s.lbl[lang]}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
