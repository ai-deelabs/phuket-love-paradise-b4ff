---
import { getCollection } from 'astro:content';
import type { Lang } from '../i18n/config';
import { useT } from '../i18n/ui';
import { catalogUrl, categoryUrl } from '../lib/routes';

interface Props {
  lang: Lang;
  /** category id currently shown, or 'all' for the catalog page. */
  active: string;
  /** true when rendered on a light background. */
  onLight?: boolean;
}
const { lang, active, onLight = false } = Astro.props;
const t = useT(lang);
const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
---

<nav class:list={['chips', { 'on-light': onLight }]} aria-label={t('nav.categories')}>
  <a href={catalogUrl(lang)} class:list={['chip', { active: active === 'all' }]}>
    {t('common.allTours')}
  </a>
  {
    categories.map((c) => (
      <a href={categoryUrl(c, lang)} class:list={['chip', { active: active === c.id }]}>
        {c.data.shortTitle?.[lang] ?? c.data.title[lang]}
      </a>
    ))
  }
</nav>
