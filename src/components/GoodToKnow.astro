---

<section class="sec gtk" id="info">
  <div class="container">
    <div class="center-text reveal" style="margin-bottom:2.75rem">
      <div class="sec-label center">
        <span>{t(label, lang)}</span>
      </div>
      <h2 class="sec-title lt">{t(title, lang)}</h2>
    </div>
    <div class="gtk__grid">
      {
        listCards.map((card) => (
          <div class={card.cls}>
            <div class="gtk-card__ic">
              <Icon name={card.icon} size={20} />
            </div>
            <h3>{t(card.title, lang)}</h3>
            <ul>
              {card.items.map((item) => (
                <li>
                  <Icon name={item.icon} size={16} />
                  <span>{t(item.text, lang)}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="gtk-card reveal rd2">
        <div class="gtk-card__ic"><Icon name="phone" size={20} /></div>
        <h3>{t(contactsTitle, lang)}</h3>
        <div class="gtk-contacts">
          {
            operators.map((op) => (
              <div class="op">
                {op.name}
                <span>{t(op.info, lang)}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
