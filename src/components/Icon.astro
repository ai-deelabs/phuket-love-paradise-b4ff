---
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 16, class: cls } = Astro.props;

const require = createRequire(import.meta.url);
let svg = readFileSync(require.resolve(`lucide-static/icons/${name}.svg`), 'utf-8');
svg = svg
  .replace(/<!--.*?-->/gs, '')
  .replace(
    /<svg([^>]*)width="24" height="24"/,
    `<svg$1width="${size}" height="${size}"${cls ? ` class="${cls}"` : ''}`,
  )
  .trim();
---

<Fragment set:html={svg} />
