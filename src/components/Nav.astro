---
import { LANG_LABELS, LOCALES, type Lang } from '../i18n/config';
import { useT } from '../i18n/ui';
import type { Alternates } from '../lib/routes';
import { cartUrl, catalogUrl, categoryUrl, homeUrl, howToBookUrl } from '../lib/routes';
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  alternates: Alternates;
}
const { lang, alternates } = Astro.props;
const t = useT(lang);

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const packagesCat = categories.find((c) => c.id === 'packages');

const links = [
  { href: homeUrl(lang), label: t('nav.home') },
  { href: catalogUrl(lang), label: t('nav.tours') },
  ...(packagesCat ? [{ href: categoryUrl(packagesCat, lang), label: packagesCat.data.shortTitle?.[lang] ?? packagesCat.data.title[lang] }] : []),
  { href: howToBookUrl(lang), label: t('nav.howToBook') },
];
---

<nav class="nav" id="navbar">
  <a class="nav__brand" href={homeUrl(lang)}>
    <div class="nav__brand-th">ภูเก็ตเลิฟพาราไดซ์</div>
    <div class="nav__brand-en">Phuket Love Paradise</div>
  </a>
  <div class="nav__right">
    <ul class="nav__links">
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
    <div class="lang-sw" role="group" aria-label="Language">
      <Icon name="globe" size={14} />
      {LOCALES.map((l) => (
        <a href={alternates[l]} class:list={['lang-sw__opt', { active: l === lang }]} lang={l} hreflang={l}>
          {LANG_LABELS[l]}
        </a>
      ))}
    </div>
    <a class="nav__cart" href={cartUrl(lang)} aria-label={t('nav.cart')}>
      <Icon name="shopping-cart" size={20} />
      <span class="nav__cart-n" id="cartBadge">0</span>
    </a>
    <button class="nav__burger" id="burger" aria-label="Menu">
      <Icon name="menu" size={22} />
    </button>
  </div>
  <div class="nav__drawer" id="drawer">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    {categories.filter((c) => c.id !== 'packages').map((c) => (
      <a href={categoryUrl(c, lang)}>{c.data.title[lang]}</a>
    ))}
  </div>
</nav>

<style>
  .lang-sw__opt {
    color: rgba(255, 255, 255, 0.6);
    padding: 0 0.15rem;
    transition: color 0.2s;
  }
  .lang-sw__opt:hover {
    color: var(--gold-light);
  }
  .lang-sw__opt.active {
    color: var(--gold);
  }
  .lang-sw__opt:not(:last-child)::after {
    content: '·';
    color: rgba(255, 255, 255, 0.25);
    padding-left: 0.3rem;
  }
</style>

<script>
  import { bindBadge } from '../scripts/cart';
  const badge = document.getElementById('cartBadge');
  if (badge) bindBadge(badge);
</script>
