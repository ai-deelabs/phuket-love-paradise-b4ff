---
import { getCollection } from 'astro:content';
import CategoryView from '../../../views/CategoryView.astro';
import { PREFIXED_LOCALES, type Lang } from '../../../i18n/config';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  return PREFIXED_LOCALES.flatMap((lang) =>
    categories.map((category) => ({
      params: { lang, category: category.data.slugs[lang] },
      props: { category },
    })),
  );
}
const { category } = Astro.props;
const lang = Astro.params.lang as Lang;
---

<CategoryView lang={lang} category={category} />
