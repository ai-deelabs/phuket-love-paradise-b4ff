---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/config';
import type { Alternates } from '../lib/routes';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  alternates: Alternates;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
  bodyClass?: string;
}

const { lang, title, description, alternates, ogImage, ogType, noindex, jsonLd, bodyClass } =
  Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      lang={lang}
      title={title}
      description={description}
      alternates={alternates}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body class={bodyClass}>
    <Nav lang={lang} alternates={alternates} />
    <slot />
    <Footer lang={lang} />
    <script>
      import '../scripts/site';
    </script>
  </body>
</html>
