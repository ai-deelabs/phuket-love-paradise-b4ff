---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CategoryChips from '../components/CategoryChips.astro';
import Icon from '../components/Icon.astro';
import TourCard from '../components/TourCard.astro';
import type { Lang } from '../i18n/config';
import { useT } from '../i18n/ui';
import {
  catalogUrl,
  categoryAlternates,
  categoryUrl,
  homeUrl,
  howToBookUrl,
  tourUrl,
} from '../lib/routes';
import { breadcrumbSchema, itemListSchema } from '../lib/seo';

interface Props {
  lang: Lang;
  category: CollectionEntry<'categories'>;
}
const { lang, category } = Astro.props;
const t = useT(lang);
const d = category.data;

const tours = (await getCollection('tours'))
  .filter((tour) => tour.data.categories.some((c) => c.id === category.id))
  .sort((a, b) => a.data.order - b.data.order);

const alternates = categoryAlternates(category);
const site = Astro.site!;
const jsonLd = [
  breadcrumbSchema([
    { name: t('nav.home'), url: new URL(homeUrl(lang), site).href },
    { name: t('nav.tours'), url: new URL(catalogUrl(lang), site).href },
    { name: d.title[lang], url: new URL(categoryUrl(category, lang), site).href },
  ]),
  itemListSchema(
    tours.map((tour) => ({ name: tour.data.title[lang], url: new URL(tourUrl(tour, lang), site).href })),
  ),
];

const isPackages = category.id === 'packages';
const ctaTitle = {
  th: 'อยากได้แพ็คเกจหลายวันแบบจัดเอง?',
  en: 'Want a custom multi-day package?',
  ru: 'Нужен индивидуальный многодневный пакет?',
}[lang];
const ctaText = {
  th: 'บอกจำนวนวัน งบประมาณ และสิ่งที่อยากทำ ทีมงานจะจัดโปรแกรมพร้อมราคาให้ฟรี ไม่มีข้อผูกมัด',
  en: 'Tell us your days, budget and wishlist — our team will craft an itinerary with prices for free, no obligation.',
  ru: 'Расскажите о датах, бюджете и пожеланиях — мы бесплатно составим программу с ценами, без обязательств.',
}[lang];
---

<BaseLayout
  lang={lang}
  title={d.seo.title[lang]}
  description={d.seo.description[lang]}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <header class="page-hero">
    <div class="page-hero__inner">
      <Breadcrumbs
        items={[
          { label: t('nav.home'), href: homeUrl(lang) },
          { label: t('nav.tours'), href: catalogUrl(lang) },
          { label: d.title[lang] },
        ]}
      />
      <h1 class="sec-title">{d.title[lang]}</h1>
      <p class="sec-desc">{d.description[lang]}</p>
      <CategoryChips lang={lang} active={category.id} />
    </div>
  </header>
  <section class="sec tours">
    <div class="container">
      <div class="pgrid">
        {tours.map((tour, i) => <TourCard tour={tour} lang={lang} loading={i < 3 ? 'eager' : 'lazy'} />)}
        {
          isPackages && (
            <article class="pcard pcard--cta">
              <Icon name="messages-square" size={34} />
              <h3>{ctaTitle}</h3>
              <p>{ctaText}</p>
              <a class="btn-gold" href={howToBookUrl(lang)}>
                {t('nav.contact')}
                <Icon name="arrow-right" size={15} />
              </a>
            </article>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
