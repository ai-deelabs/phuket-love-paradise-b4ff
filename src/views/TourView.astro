---
import { Image, getImage } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingBox from '../components/BookingBox.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DetailsPanel from '../components/DetailsPanel.astro';
import Icon from '../components/Icon.astro';
import ItineraryList from '../components/ItineraryList.astro';
import PriceTable from '../components/PriceTable.astro';
import StickyBookBar from '../components/StickyBookBar.astro';
import TourCard from '../components/TourCard.astro';
import type { Lang } from '../i18n/config';
import { useT } from '../i18n/ui';
import { assetImage } from '../lib/images';
import { catalogUrl, homeUrl, tourAlternates, tourUrl } from '../lib/routes';
import { breadcrumbSchema, productSchema, touristTripSchema } from '../lib/seo';

interface Props {
  lang: Lang;
  tour: CollectionEntry<'tours'>;
}
const { lang, tour } = Astro.props;
const t = useT(lang);
const d = tour.data;

const alternates = tourAlternates(tour);
const site = Astro.site!;
const url = new URL(tourUrl(tour, lang), site).href;

const heroImg = assetImage(d.hero);
const ogImg = await getImage({ src: heroImg, width: 1200, height: 630, format: 'jpeg' });

const jsonLd = [
  productSchema(tour, lang, url, new URL(ogImg.src, site).href),
  touristTripSchema(tour, lang, url),
  breadcrumbSchema([
    { name: t('nav.home'), url: new URL(homeUrl(lang), site).href },
    { name: t('nav.tours'), url: new URL(catalogUrl(lang), site).href },
    { name: d.title[lang], url },
  ]),
];

const related = (await getCollection('tours'))
  .filter(
    (other) =>
      other.id !== tour.id &&
      other.data.categories.some((c) => d.categories.some((mine) => mine.id === c.id)),
  )
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  lang={lang}
  title={d.seo.title[lang]}
  description={d.seo.description[lang]}
  alternates={alternates}
  ogImage={ogImg.src}
  ogType="product"
  jsonLd={jsonLd}
  bodyClass="has-sbar"
>
  <header class="page-hero">
    <div class="page-hero__inner">
      <Breadcrumbs
        items={[
          { label: t('nav.home'), href: homeUrl(lang) },
          { label: t('nav.tours'), href: catalogUrl(lang) },
          { label: d.title[lang] },
        ]}
      />
      <h1 class="sec-title">{d.title[lang]}</h1>
      {d.operatingDays && (
        <p class="sec-desc">
          <Icon name="calendar-days" size={14} /> {d.operatingDays[lang]}
        </p>
      )}
    </div>
  </header>

  <section class="sec tourpg">
    <div class="container">
      <div class="tourpg__grid">
        <div class="tourpg__main">
          <div class="tourpg__hero">
            <Image
              src={heroImg}
              alt={d.title[lang]}
              width={1200}
              height={630}
              loading="eager"
              fetchpriority="high"
            />
            {d.badge && <span class="pcard__tag">{d.badge[lang]}</span>}
          </div>

          <div class="tour-meta" style="margin-bottom:1.1rem">
            {d.meta.map((m) => (
              <div class="tour-meta-i">
                <Icon name={m.icon} size={14} />
                <span>{m.text[lang]}</span>
              </div>
            ))}
          </div>

          <p class="tourpg__sum">{d.summary[lang]}</p>

          {d.highlights.length > 0 && (
            <ul class="tour-hl">
              {d.highlights.map((h) => (
                <li>
                  <Icon name={h.icon} size={14} />
                  <span>{h.text[lang]}</span>
                </li>
              ))}
            </ul>
          )}

          <DetailsPanel icon="tags" label={t('tour.priceTable')} open={true}>
            <PriceTable tour={tour} lang={lang} />
            {d.parkFees && (
              <p class="tdetails__note">
                <strong>{t('tour.parkFees')}:</strong> {d.parkFees[lang]}
              </p>
            )}
          </DetailsPanel>

          {d.itinerary.length > 0 && (
            <DetailsPanel icon="route" label={t('tour.itinerary')}>
              <ItineraryList itinerary={d.itinerary} lang={lang} />
            </DetailsPanel>
          )}

          {(d.includes.length > 0 || d.excludes.length > 0) && (
            <DetailsPanel icon="list-checks" label={`${t('tour.includes')} / ${t('tour.excludes')}`}>
              {d.includes.length > 0 && (
                <ul class="itin-list">
                  {d.includes.map((inc) => (
                    <li>
                      <span class="t"><Icon name="check" size={13} /></span>
                      <span>{inc[lang]}</span>
                    </li>
                  ))}
                </ul>
              )}
              {d.excludes.length > 0 && (
                <ul class="itin-list" style="margin-top:.6rem">
                  {d.excludes.map((exc) => (
                    <li>
                      <span class="t"><Icon name="x" size={13} /></span>
                      <span>{exc[lang]}</span>
                    </li>
                  ))}
                </ul>
              )}
            </DetailsPanel>
          )}

          {d.notes.length > 0 && (
            <DetailsPanel icon="info" label={t('tour.notes')}>
              {d.notes.map((n) => (
                <p class="tdetails__note">
                  {n.heading && <strong>{n.heading[lang]}: </strong>}
                  {n.text[lang]}
                </p>
              ))}
            </DetailsPanel>
          )}

          {d.gallery.length > 0 && (
            <div class="gallery__grid" style="margin-top:1.5rem">
              {d.gallery.map((g) => (
                <div class="gal-item" style="height:180px">
                  <Image src={assetImage(g)} alt={d.title[lang]} width={600} height={400} />
                </div>
              ))}
            </div>
          )}
        </div>

        <aside class="tourpg__aside">
          <BookingBox tour={tour} lang={lang} />
        </aside>
      </div>

      {related.length > 0 && (
        <div style="margin-top:3.5rem">
          <div class="sec-label">{t('tour.related')}</div>
          <div class="pgrid">
            {related.map((r) => <TourCard tour={r} lang={lang} />)}
          </div>
        </div>
      )}
    </div>
  </section>

  <StickyBookBar tour={tour} lang={lang} />
</BaseLayout>
